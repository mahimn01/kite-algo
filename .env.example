# -----------------------------------------------------------------------------
# Kite Connect credentials (Zerodha)
# -----------------------------------------------------------------------------
# Get these from https://developers.kite.trade/apps after creating a Kite
# Connect app (requires ₹2000/month subscription).

KITE_API_KEY=
KITE_API_SECRET=

# Access token — rotates daily at ~6am IST. Generated by `kite-algo login`.
# Leave blank; the login command will write this via data/session.json.
KITE_ACCESS_TOKEN=

# Your Zerodha user id (e.g. AB1234). Used for audit logging, not auth.
KITE_USER_ID=

# -----------------------------------------------------------------------------
# Broker selection
# -----------------------------------------------------------------------------
TRADING_BROKER=kite   # kite | sim

# -----------------------------------------------------------------------------
# Safety rails (same pattern as trading-algo / IBKR)
# -----------------------------------------------------------------------------

# Allow connecting to the real Kite account (as opposed to sim).
TRADING_ALLOW_LIVE=false

# Second gate: refuse to place orders unless explicitly enabled.
TRADING_LIVE_ENABLED=false

# Stage orders only — never actually transmit.
TRADING_DRY_RUN=true

# Second confirmation token — must match --confirm-token if
# TRADING_CONFIRM_TOKEN_REQUIRED=true.
TRADING_ORDER_TOKEN=
TRADING_CONFIRM_TOKEN_REQUIRED=false

# Optional: enable sqlite audit trail.
TRADING_DB_PATH=

# -----------------------------------------------------------------------------
# Market / instruments
# -----------------------------------------------------------------------------

# Which segments to pre-cache instruments for (comma-separated).
# Valid: NSE, BSE, NFO, BFO, MCX, CDS.
KITE_EXCHANGES=NSE,NFO

# Instrument cache TTL (seconds). Kite refreshes the dump daily ~8:30am IST.
KITE_INSTRUMENTS_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Strategy loop
# -----------------------------------------------------------------------------
TRADING_POLL_SECONDS=5

# -----------------------------------------------------------------------------
# Optional: LLM trader / chat (parity with trading-algo)
# -----------------------------------------------------------------------------
LLM_ENABLED=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
